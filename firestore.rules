rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          in ['admin', 'super-admin'];
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Users can only read their own document.
    // All writes go through the server-side Admin SDK — no client writes allowed.

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;

      // Watch history — users can read and write their own history only
      match /watchHistory/{videoId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Videos ───────────────────────────────────────────────────────────────
    // Public: anyone can read published videos.
    // Admins can read all statuses (draft, scheduled, archived, processing).
    // No client writes — video CRUD is server-side only.

    match /videos/{videoId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if false;
    }

    // ── Transactions ─────────────────────────────────────────────────────────
    // Users can only read their own transactions (receipts, history).
    // No client writes — transactions are created server-side only.

    match /transactions/{txId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Platform Stats ────────────────────────────────────────────────────────
    // Internal admin counters — no client access whatsoever.

    match /platformStats/{docId} {
      allow read, write: if false;
    }

    // ── Support Chat ──────────────────────────────────────────────────────────
    // Premium users can read/write their own conversation document and messages.
    // Admins can read/write all conversations (to reply to users).

    function isPremiumUser() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscription.status
          in ['active', 'canceling'];
    }

    match /supportChats/{userId} {
      // Owner (premium) or admin can read/write the conversation metadata
      allow read: if isOwner(userId) || isAdmin();
      allow write: if (isOwner(userId) && isPremiumUser()) || isAdmin();

      match /messages/{msgId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) && isPremiumUser()) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // ── Deny-by-default ──────────────────────────────────────────────────────
    // Catch-all: block every path not explicitly matched above.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
